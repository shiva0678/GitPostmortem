# Backend environment example — copy to backend/.env and fill secrets
# NEVER commit backend/.env with secrets to source control.

# GitHub Personal Access Token (recommended to increase rate limit)
# Scopes: public_repo (or repo for private repos)
GITHUB_TOKEN=

# Google Gemini API key (optional) — enables AI-powered analysis
GEMINI_API_KEY=

# Server settings
HOST=0.0.0.0
PORT=8000
ENV=development
