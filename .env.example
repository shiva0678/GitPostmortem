# =============================================================================
# GitPostmortem — Environment Variable Reference
# =============================================================================
# Copy this file to configure your environment:
#
#   Frontend (local dev):  cp .env.example .env.local
#   Backend:               cp .env.example backend/.env
#
# NEVER commit .env.local or backend/.env — they are git-ignored.
# This file (.env.example) is safe to commit — it contains no secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# FRONTEND VARIABLES  (prefix: VITE_)
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# -----------------------------------------------------------------------------

# URL of the backend /api/analyze endpoint.
#
# Local dev:   Leave as /api/analyze — the Vite dev server proxy (vite.config.js)
#              forwards /api/* to http://localhost:8000 automatically.
#
# Production:  Set to your deployed backend URL, e.g.:
#              VITE_API_URL=https://your-backend.onrender.com/api/analyze
#
VITE_API_URL=/api/analyze


# -----------------------------------------------------------------------------
# BACKEND VARIABLES  (used by FastAPI via python-dotenv in backend/.env)
# These are NEVER exposed to the browser.
# -----------------------------------------------------------------------------

# GitHub Personal Access Token (strongly recommended).
# Without this, the GitHub API rate limit is 60 requests/hour (unauthenticated).
# With a token, the limit is 5,000 requests/hour.
#
# Create a token at: https://github.com/settings/tokens
# Required scopes:   public_repo  (for public repositories)
#                    repo         (to also analyse private repositories)
#
# SECRET — do not commit the actual value.
GITHUB_TOKEN=

# Google Gemini API Key (required for AI-powered analysis).
# Without this, the backend falls back to rule-based heuristics.
#
# Get a key at: https://aistudio.google.com/app/apikey
#
# SECRET — do not commit the actual value.
GEMINI_API_KEY=

# FastAPI server bind settings (optional — defaults shown).
HOST=0.0.0.0
PORT=8000

# Execution environment. Affects logging verbosity.
# Values: development | production
ENV=development
